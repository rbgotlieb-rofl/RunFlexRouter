# Copy this file to .env and fill in your values
# DO NOT commit .env to Git!

# Required: Mapbox token for server-side API calls (directions, geocoding)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Optional: URL-restricted public token for client-side map rendering.
# Create a separate token in your Mapbox dashboard with URL restrictions.
# If not set, MAPBOX_ACCESS_TOKEN is used for both (less secure).
# MAPBOX_PUBLIC_TOKEN=your_public_mapbox_token_here

# Required for iOS/Capacitor builds: URL of your backend server.
# Set this before running `npm run build:ios`.
# VITE_API_URL=https://your-app.up.railway.app

# Required for data persistence: PostgreSQL connection string (Neon recommended).
# Without this, the app uses in-memory storage (data lost on restart).
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Session secret for express-session (change in production!)
SESSION_SECRET=change-me-to-a-random-string

# Resend API key for transactional emails (password reset, etc.)
# Sign up free at https://resend.com — 3,000 emails/month on the free tier.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# "From" address for outgoing emails (must match a verified Resend domain).
# EMAIL_FROM=RunFlex <noreply@yourdomain.com>

# Public URL of your app (used to build password-reset links in emails).
# If not set, the URL is inferred from the incoming request headers.
# APP_URL=https://your-app.up.railway.app
